
{{> head}}
{{> header}}

<article>
  <h1>Book: {{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

  {{#errors}}
  <div class="alert error" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/courses/{{course.id}}/book">
    <!-- If you add CSRF later: <input type="hidden" name="_csrf" value="{{csrfToken}}"> -->
    <input type="hidden" name="userId" value="{{user._id}}">

    <fieldset>
      <legend>Your details</legend>

      <div class="field">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" required value="{{user.name}}">
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required value="{{user.email}}">
      </div>

      <div class="field">
        <label for="notes">Notes (injuries, preferences)</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
      </div>

      <div class="field checkbox">
        <input id="consent" name="consent" type="checkbox" required>
        <label for="consent">I agree to the studio’s booking terms &amp; health disclaimer.</label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Booking options</legend>
      <p>You can book the entire course or individual sessions:</p>
      
      <div class="booking-options">
        <div class="option">
          <h3>Book Entire Course</h3>
          <p>Reserve a seat across all <strong>{{sessionsCount}}</strong> sessions:</p>
          <ul class="muted">
            {{#sessions}}
            <li>{{start}} ({{remaining}} places left)</li>
            {{/sessions}}
          </ul>
          <button class="btn primary" type="submit">Confirm Course Booking</button>
        </div>
        
        <div class="option">
          <h3>Book Individual Sessions</h3>
          <p>Select specific sessions to book:</p>
          {{#sessions}}
          <div class="session-item">
            <span>{{start}} ({{remaining}} places left)</span>
            <form method="post" action="/sessions/{{id}}/book" style="display: inline;">
              <button class="btn secondary" type="submit" {{^canBook}}disabled{{/canBook}}>Book This Session</button>
            </form>
          </div>
          {{/sessions}}
        </div>
      </div>
    </fieldset>
  </form>

  <div class="actions">
    <a href="/courses/{{course.id}}" class="btn">Cancel</a>
  </div>
</article>

{{> footer}}
