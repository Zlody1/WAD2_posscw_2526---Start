
{{> head}}
{{> header}}

<section>
  <h1>Find Courses</h1>
  <form method="get" action="/courses" class="filter-form">
    <div class="filter-group">
      <label for="level">
        Level:
        <select id="level" name="level">
          <option value="">All Levels</option>
          <option value="beginner" {{#filters.level_beginner}}selected{{/filters.level_beginner}}>Beginner</option>
          <option value="intermediate" {{#filters.level_intermediate}}selected{{/filters.level_intermediate}}>Intermediate</option>
          <option value="advanced" {{#filters.level_advanced}}selected{{/filters.level_advanced}}>Advanced</option>
        </select>
      </label>

      <label for="type">
        Type:
        <select id="type" name="type">
          <option value="">All Types</option>
          <option value="WEEKLY_BLOCK" {{#filters.type_weekly}}selected{{/filters.type_weekly}}>Weekly Block</option>
          <option value="WEEKEND_WORKSHOP" {{#filters.type_workshop}}selected{{/filters.type_workshop}}>Weekend Workshop</option>
        </select>
      </label>

      <label for="dropin">
        Drop-in:
        <select id="dropin" name="dropin">
          <option value="">Any</option>
          <option value="yes" {{#filters.dropin_yes}}selected{{/filters.dropin_yes}}>Yes</option>
          <option value="no" {{#filters.dropin_no}}selected{{/filters.dropin_no}}>No</option>
        </select>
      </label>

      <label for="q">
        Search:
        <input type="search" id="q" name="q" value="{{filters.q}}" placeholder="Title or description" />
      </label>
    </div>

    <div class="filter-actions">
      <button class="btn primary" type="submit">Apply Filters</button>
      <a href="/courses" class="btn secondary">Reset</a>
    </div>
  </form>
</section>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p>{{description}}</p>
    {{#location}}<p class="muted">Location: {{location}}</p>{{/location}}
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
    <p><a href="/courses/{{id}}">View &amp; Book</a></p>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses match your filters.</p>
  {{/courses}}
</div>

<nav class="pagination">
  {{#pagination.hasPrev}}
    <a href="{{pagination.prevLink}}">← Previous</a>
  {{/pagination.hasPrev}}

  <span class="muted">Page {{pagination.page}} of {{pagination.totalPages}}</span>

  {{#pagination.hasNext}}
    <a href="{{pagination.nextLink}}">Next →</a>
  {{/pagination.hasNext}}
</nav>

{{> footer}}
