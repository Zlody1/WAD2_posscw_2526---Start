{{> head}}
{{> header}}

<article>
  <h1>Organizer Dashboard</h1>
  <p>Welcome, {{user.email}}!</p>
  
  <section>
    <h2>Manage Courses</h2>
    <a href="/organizer/courses/new" class="btn primary">Create New Course</a>
    <a href="/organizer/users" class="btn secondary">Manage Users</a>
  </section>

  {{#courses}}
  {{#@first}}
  <section>
    <h2>All Courses ({{courseCount}})</h2>
    <div class="courses-grid">
  {{/@first}}
      <div class="course-card">
        <div class="course-header">
          <h3>{{title}}</h3>
          <div class="course-badges">
            <span class="badge level-{{level}}">{{level}}</span>
            <span class="badge type-{{type}}">{{type}}</span>
          </div>
        </div>
        
        <div class="course-details">
          <div class="detail-row">
            <span class="label">Dates:</span>
            <span>{{startDate}} – {{endDate}}</span>
          </div>
          <div class="detail-row">
            <span class="label">Sessions:</span>
            <span>{{sessionsCount}} session{{#sessionsPlural}}s{{/sessionsPlural}}</span>
          </div>
        </div>
        
        <div class="course-actions">
          <a href="/organizer/courses/{{id}}" class="btn">View Details</a>
          <a href="/organizer/courses/{{id}}/students" class="btn secondary">View Students</a>
          <a href="/organizer/courses/{{id}}/edit" class="btn secondary">Edit</a>
          <a href="/organizer/courses/{{id}}/bookings" class="btn">View Bookings</a>
          <form method="post" action="/organizer/courses/{{id}}/delete" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this course? This will also delete all sessions and bookings.')">
            <button type="submit" class="btn danger">Delete</button>
          </form>
        </div>
      </div>
  {{#@last}}
    </div>
  </section>
  {{/@last}}
  {{/courses}}

  {{^courses}}
  <p>No courses yet. <a href="/organizer/courses/new">Create one now</a>.</p>
  {{/courses}}
</article>

{{> footer}}
